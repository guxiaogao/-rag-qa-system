# ========== 通义千问 DashScope API Key ==========
# 在 https://dashscope.aliyun.com/ 申请
DASHSCOPE_API_KEY=your_api_key_here

# ========== DashScope OpenAI 兼容接口地址 ==========
# 一般不需要改
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ========== 模型配置 ==========
# 生成答案用的模型（qwen-plus 效果较好，qwen-turbo 更快更便宜）
CHAT_MODEL=qwen-plus

# 向量化用的 embedding 模型
EMBEDDING_MODEL=text-embedding-v2

# 评估时做裁判用的模型（用便宜的就行）
JUDGE_MODEL=qwen-turbo

# ========== 检索参数 ==========
# 文档分块大小（字符数）
CHUNK_SIZE=500

# 分块重叠（避免切断关键信息）
CHUNK_OVERLAP=100

# 检索返回的候选 chunk 数量
TOP_K=5

# ========== 重排序配置（DashScope Rerank API）==========
# 是否启用重排序（服务端总开关）
# 开启后，API 中传 use_reranker=true 的请求会调用 DashScope gte-rerank 模型精排
# 注意：走 API 按 token 计费（极低），无需本地 GPU/内存
RERANK_ENABLED=false

# 重排序模型
# gte-rerank 是阿里通义实验室的中英双语重排序模型
RERANK_MODEL=gte-rerank

# 重排序时第一阶段检索的候选数量
# 先从向量库取 RERANK_FETCH_K 个，再用 Rerank API 精排取 TOP_K 个
RERANK_FETCH_K=20

# ========== Query Rewrite 配置 ==========
# 是否启用查询重写（服务端总开关）
# 开启后，API 中传 use_rewrite=true 的请求会先用 LLM 重写查询关键词
REWRITE_ENABLED=false

# 用于查询重写的模型（用便宜的就行，qwen-turbo 足够）
REWRITE_MODEL=qwen-turbo

# ========== Self-RAG 配置 ==========
# 是否启用 Self-RAG 自我反思（服务端总开关）
# 开启后，API 中传 use_self_rag=true 的请求会在生成后自动检查忠实度
# 如果发现幻觉 → 自动精炼查询 → 重新检索 → 重新生成
SELF_RAG_ENABLED=false

# 最大精炼轮次（超过此轮次停止，即使忠实度仍未达标）
SELF_RAG_MAX_ROUNDS=2

# 忠实度阈值（0-1），低于此分数触发精炼
SELF_RAG_FAITHFULNESS_THRESHOLD=0.7

# 精炼轮次中重新检索的 top_k
SELF_RAG_REFINE_TOP_K=3

# ========== Web 搜索 fallback 配置 ==========
# 是否启用 Web 搜索 fallback（服务端总开关）
# 关闭后即使 API 传 use_web_search=true 也不生效
WEB_SEARCH_ENABLED=false

# 知识库检索相关性阈值（0-1）
# KB 最高分低于此值时，自动从 DuckDuckGo 搜索网页结果补全上下文
# 设为 0 表示永远触发；设为 1 表示永不触发
WEB_SEARCH_FALLBACK_THRESHOLD=0.3

# Web 搜索结果数量
WEB_SEARCH_NUM_RESULTS=5

# ========== 向量数据库 ==========
# ChromaDB 持久化路径（相对于项目根目录）
CHROMA_DB_PATH=data/chroma_db

# ChromaDB 集合名称
CHROMA_COLLECTION_NAME=rag_documents

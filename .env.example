# ========== 通义千问 DashScope API Key ==========
# 在 https://dashscope.aliyun.com/ 申请
DASHSCOPE_API_KEY=your_api_key_here

# ========== DashScope OpenAI 兼容接口地址 ==========
# 一般不需要改
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ========== 模型配置 ==========
# 生成答案用的模型（2026年推荐）
#   qwen-turbo          — 低延迟，响应最快 ★ 推荐默认
#   qwen3.5-flash       — 新一代轻量，推理强中文好（约 ¥0.002/k tokens）
#   qwen3.5-plus        — 性价比之王，推理强中文好（约 ¥0.008/k tokens）
#   qwen3.7-max         — 最新旗舰，最强推理（贵，约 ¥0.04/k tokens）
CHAT_MODEL=qwen-turbo

# 向量化用的 embedding 模型
EMBEDDING_MODEL=text-embedding-v3

# 评估/裁判用的模型（qwen-turbo 低延迟，打分快）
JUDGE_MODEL=qwen-turbo

# ========== 检索参数 ==========
# 文档分块大小（字符数）
CHUNK_SIZE=500

# 分块重叠（避免切断关键信息）
CHUNK_OVERLAP=100

# 检索返回的候选 chunk 数量
TOP_K=5

# ========== 重排序配置（DashScope Rerank API）==========
# 是否启用重排序（服务端总开关，建议开启）
# 开启后，API 中传 use_reranker=true 的请求会调用 DashScope qwen3-rerank 模型精排
# 注意：走 API 按 token 计费（极低），无需本地 GPU/内存
RERANK_ENABLED=true

# 重排序模型
# qwen3-rerank 是阿里通义千问新一代重排序模型（gte-rerank 已于 2026-05-30 下线）
RERANK_MODEL=qwen3-rerank

# 重排序时第一阶段检索的候选数量
# 先从向量库取 RERANK_FETCH_K 个，再用 Rerank API 精排取 TOP_K 个
RERANK_FETCH_K=10

# ========== Query Rewrite 配置 ==========
# 是否启用查询重写（服务端总开关）
# 开启后每次请求增加 1 次额外 LLM 调用（+1-20s），建议关闭
REWRITE_ENABLED=false

# 用于查询重写的模型（qwen-turbo 低延迟，关键词提取足够）
REWRITE_MODEL=qwen-turbo

# ========== LLM 生成参数 ==========
# 生成温度（0-1），越高越随机、越低越确定
LLM_TEMPERATURE=0.8

# ========== Embedding 参数 ==========
# Embedding API 单次请求最大文本数（百炼平台限制 10）
EMBEDDING_BATCH_SIZE=10

# ========== Web 搜索 fallback 配置 ==========
# 是否启用 Web 搜索 fallback（服务端总开关）
# 开启后 KB 检索质量不足时自动从 DuckDuckGo 搜索互联网补全，会增加 1-5s 同步阻塞
WEB_SEARCH_ENABLED=false

# 知识库检索相关性阈值（0-1）
# KB 最高分低于此值时，自动从 DuckDuckGo 搜索网页结果补全上下文
# 设为 0 表示永远触发；设为 1 表示永不触发
WEB_SEARCH_FALLBACK_THRESHOLD=0.3

# Web 搜索结果数量
WEB_SEARCH_NUM_RESULTS=5

# ========== CORS 配置 ==========
# 允许的跨域来源，逗号分隔多个域名。
# 开发/本地调试使用 "*"（默认）；生产环境请设置为具体域名，如 "https://your-app.example.com"
CORS_ORIGINS=*

# ========== 日志配置 ==========
# 业务日志级别。开发环境用 info/debug，生产环境用 warning。
# 注意：uvicorn 自身的 HTTP 访问日志级别由启动参数 --log-level 独立控制。
RAG_LOG_LEVEL=info

# ========== 向量数据库 ==========
# ChromaDB 持久化路径（相对于项目根目录）
CHROMA_DB_PATH=data/chroma_db

# ChromaDB 集合名称
CHROMA_COLLECTION_NAME=rag_documents

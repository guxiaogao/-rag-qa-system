# ========== 通义千问 DashScope API Key ==========
# 在 https://dashscope.aliyun.com/ 申请
DASHSCOPE_API_KEY=your_api_key_here

# ========== DashScope OpenAI 兼容接口地址 ==========
# 一般不需要改
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ========== 模型配置 ==========
# 生成答案用的模型（qwen-plus 效果较好，qwen-turbo 更快更便宜）
CHAT_MODEL=qwen-plus

# 向量化用的 embedding 模型
EMBEDDING_MODEL=text-embedding-v3

# 评估时做裁判用的模型（用便宜的就行）
JUDGE_MODEL=qwen-turbo

# ========== 检索参数 ==========
# 文档分块大小（字符数）
CHUNK_SIZE=500

# 分块重叠（避免切断关键信息）
CHUNK_OVERLAP=100

# 检索返回的候选 chunk 数量
TOP_K=5

# ========== 重排序配置（DashScope Rerank API）==========
# 是否启用重排序（服务端总开关，建议开启）
# 开启后，API 中传 use_reranker=true 的请求会调用 DashScope gte-rerank 模型精排
# 注意：走 API 按 token 计费（极低），无需本地 GPU/内存
RERANK_ENABLED=true

# 重排序模型
# gte-rerank 是阿里通义实验室的中英双语重排序模型
RERANK_MODEL=gte-rerank

# 重排序时第一阶段检索的候选数量
# 先从向量库取 RERANK_FETCH_K 个，再用 Rerank API 精排取 TOP_K 个
RERANK_FETCH_K=20

# ========== Query Rewrite 配置 ==========
# 是否启用查询重写（服务端总开关）
# 开启后，API 中传 use_rewrite=true 的请求会先用 LLM 重写查询关键词
REWRITE_ENABLED=true

# 用于查询重写的模型（用便宜的就行，qwen-turbo 足够）
REWRITE_MODEL=qwen-turbo

# ========== LLM 生成参数 ==========
# 生成温度（0-1），越高越随机、越低越确定
LLM_TEMPERATURE=0.8

# ========== Embedding 参数 ==========
# Embedding API 单次请求最大文本数（百炼平台限制 10）
EMBEDDING_BATCH_SIZE=10

# ========== Web 搜索 fallback 配置 ==========
# 是否启用 Web 搜索 fallback（服务端总开关）
# 开启后，KB 检索质量不足时自动从 DuckDuckGo 搜索互联网补全上下文。
# 依赖 DuckDuckGo 免费搜索（无需 API Key），生产环境如不需要可设为 false。
WEB_SEARCH_ENABLED=true

# 知识库检索相关性阈值（0-1）
# KB 最高分低于此值时，自动从 DuckDuckGo 搜索网页结果补全上下文
# 设为 0 表示永远触发；设为 1 表示永不触发
WEB_SEARCH_FALLBACK_THRESHOLD=0.3

# Web 搜索结果数量
WEB_SEARCH_NUM_RESULTS=5

# ========== CORS 配置 ==========
# 允许的跨域来源，逗号分隔多个域名。
# 开发/本地调试使用 "*"（默认）；生产环境请设置为具体域名，如 "https://your-app.example.com"
CORS_ORIGINS=*

# ========== 上传限制 ==========
# 单次上传文件大小上限（MB），防止超大 PDF 耗尽 embedding 配额
MAX_UPLOAD_SIZE_MB=10

# ========== 日志配置 ==========
# 业务日志级别。开发环境用 info/debug，生产环境用 warning。
# 注意：uvicorn 自身的 HTTP 访问日志级别由启动参数 --log-level 独立控制。
RAG_LOG_LEVEL=info

# ========== 向量数据库 ==========
# ChromaDB 持久化路径（相对于项目根目录）
CHROMA_DB_PATH=data/chroma_db

# ChromaDB 集合名称
CHROMA_COLLECTION_NAME=rag_documents
